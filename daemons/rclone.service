[Unit]
Description=Rclone sync with Google Drive
After=network-online.target
OnFailure=rclone-fail.service

[Service]
Type=oneshot
ExecStart=/usr/bin/rclone bisync gdrive: %h/gdrive/ --drive-skip-gdocs --create-empty-src-dirs --log-level=ERROR
# For Type=oneshot any non-zero exit is already treated as failure, which
# triggers OnFailure=rclone-fail.service above.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
